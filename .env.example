# Navisual — Configuration
#
# Settings file location: %LOCALAPPDATA%\com.navisual.app\.env
# The app creates this file automatically on first launch.
# Copy this file there to pre-configure settings, or use the in-app
# gear icon — no .env editing required for normal use.
#
# NOTE: The project-root .env is NOT read at runtime (dev or production).
# All settings must go to %LOCALAPPDATA%\com.navisual.app\.env.

# =============================================================================
# PROVIDER SELECTION
# =============================================================================
# Which AI backend to use. Options:
# managed | anthropic | gemini | openai | deepseek | qwen | ollama
#
# - managed  : Default. Supabase relay to a free-tier AI provider (the
#              specific provider may change over time). 30 free requests per
#              device. No API key needed.
# - anthropic: Claude. Best quality. Requires ANTHROPIC_API_KEY.
# - gemini   : Free tier (~1,500 req/day). Requires GEMINI_API_KEY.
# - openai   : GPT-5 family vision. Requires OPENAI_API_KEY.
# - deepseek : Text-only (api.deepseek.com rejects images). Requires DEEPSEEK_API_KEY.
# - qwen     : Alibaba DashScope (cloud). Requires QWEN_API_KEY.
# - custom   : Any OpenAI-compatible endpoint (LM Studio/llama.cpp/vLLM/other clouds). Requires CUSTOM_BASE_URL.
# - ollama   : Local inference. No API key. Requires Ollama running.

API_PROVIDER=managed

# =============================================================================
# MANAGED (Supabase relay — default, no key required)
# =============================================================================
# The anon key is a public, non-secret key designed to be embedded in client
# apps. Defaults are baked into the binary; uncomment only to override.
# SUPABASE_URL=https://gwekzberpfuxsoddwwqj.supabase.co
# SUPABASE_ANON_KEY=<your-project-anon-key>
# MANAGED_MODEL is a display-only placeholder (shown before the first managed
# response); the relay always decides the real model server-side, this has no
# effect on routing. Not worth setting — left here only in case a Navisual.log
# line ever needs a distinguishing label. Default: "managed".
# MANAGED_MODEL=managed

# =============================================================================
# ANTHROPIC (Claude)
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-xxx
#
# Models:
#   claude-haiku-4-5-20251001  — Fastest, ~20× cheaper than Sonnet.
#   claude-sonnet-4-6          — Default. Balanced speed + quality.
#   claude-opus-4-7            — Highest quality.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# =============================================================================
# GOOGLE GEMINI (free tier)
# =============================================================================
# Get a free key at https://aistudio.google.com/apikey (no credit card)
# GEMINI_API_KEY=AIza-xxx
#
# Models:
#   gemini-2.5-flash             — Default. Free tier, strong vision, fast.
#   gemini-2.5-pro               — Highest free-tier quality.
#   gemini-3-flash-preview       — Newer preview model.
# GEMINI_MODEL=gemini-2.5-flash

# =============================================================================
# OPENAI (GPT-5)
# =============================================================================
# OPENAI_API_KEY=sk-xxx
#
# Models:
#   gpt-5.4       — Default. Vision-capable.
#   gpt-5.4-mini  — Faster, cheaper.
#   gpt-5.5       — Highest quality.
# OPENAI_MODEL=gpt-5.4

# =============================================================================
# DEEPSEEK
# =============================================================================
# Note: api.deepseek.com is text-only — screenshots are not sent. The AI works
# from your prompts + state summary alone. Useful only for text-only flows.
# DEEPSEEK_API_KEY=sk-xxx
#
# Models:
#   deepseek-v4-flash — Default.
#   deepseek-v4-pro   — Higher quality.
# DEEPSEEK_MODEL=deepseek-v4-flash

# =============================================================================
# QWEN (Alibaba DashScope)
# =============================================================================
# QWEN_API_KEY=sk-xxx
# QWEN_BASE_URL — DashScope region endpoint (the Settings "Region" picker sets this):
#   International (Singapore): https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   China (Beijing):           https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#
# Models:
#   qwen3.6-plus       — Default.
#   qwen3.6-flash      — Faster.
#   qwen3.5-omni-plus  — Multimodal.
# QWEN_MODEL=qwen3.6-plus

# =============================================================================
# CUSTOM (any OpenAI-compatible endpoint — local servers, other clouds, workspace URLs)
# =============================================================================
# CUSTOM_BASE_URL — the /v1 endpoint; Navisual appends /chat/completions.
#   LM Studio:       http://localhost:1234/v1
#   llama.cpp/vLLM:  http://localhost:8080/v1   (use the host's LAN IP from another machine)
#   DashScope (HK):  https://ws-xxx.cn-hongkong.maas.aliyuncs.com/compatible-mode/v1
# CUSTOM_BASE_URL=
# CUSTOM_MODEL=        (use a *vision* model so it can see the screen)
# CUSTOM_API_KEY=      (optional — local servers don't need one)

# =============================================================================
# OLLAMA (local — no API key, runs on your machine)
# =============================================================================
# Install: https://ollama.com   Start: ollama serve
# Vision models — pick one and `ollama pull <model>`:
#   llama3.2-vision   — Best quality. ~8 GB VRAM or 16 GB RAM.
#   llava:7b          — Lighter. ~4 GB VRAM.
#   moondream         — Very light. Minimal quality.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2-vision
# OLLAMA_TIMEOUT_SEC=120

# =============================================================================
# OVERLAY APPEARANCE
# =============================================================================
# OVERLAY_COLOR=#FF6B35
# OVERLAY_THICKNESS=4
# SUBTITLE_ENABLED=true

# =============================================================================
# BEHAVIOR
# =============================================================================
# AUTO_ADVANCE=false           # Autopilot: advance steps on screen change
# AUTOPILOT_MIN_CELLS=16       # Autopilot sensitivity: cells (of 1024) that must change to fire; lower = more sensitive (Settings slider; clamped 4–200)
# TTS_ENABLED=true             # Audio narration via Windows SAPI
# TTS_VOICE=                   # SAPI voice token ID (set via Settings → Audio)
# VOICE_INPUT_ENABLED=true     # Push-to-talk via Web Speech API
# VOICE_LANGUAGE=en-US

# =============================================================================
# HOTKEYS (Tauri accelerator format, e.g. "Ctrl+KeyE", "Ctrl+Backquote")
# All changes require an app restart.
# =============================================================================
# HOTKEY_NEXT=Ctrl+Backquote   # Advance to next step
# HOTKEY_WRONG=Ctrl+KeyE       # Re-analyze current screen (E = Error)
# HOTKEY_PAUSE=                # Pause/resume capture — unset by default (Ctrl+S conflicts with Save)
# HOTKEY_ICON=                 # Show/hide Navisual panel — unset by default (Ctrl+Q quits browsers)
# HOTKEY_TALK=Ctrl+KeyD        # Push-to-talk voice input

# =============================================================================
# DEVELOPER OPTIONS (requires app restart)
# =============================================================================
# NAVISUAL_DEV=true            # Unlock the Developer tab in Settings.
#                              # Enables: debug captures, locate trace drawer,
#                              # locate JSONL log, AI bbox overlay.
#                              # All debug flags below are ignored unless
#                              # NAVISUAL_DEV=true (or set from the Dev tab).
# TRAINING_CAPTURE_ENABLED=true # Bank complete training triples LOCALLY (never
#                              # uploaded): the exact AI-sent screenshot per
#                              # request (training\shot_<request_id>.jpg), the
#                              # prompt + parsed response in prompt_log.jsonl,
#                              # rotated logs archived to training\logs\ instead
#                              # of deleted, and worked/wrong feedback mirrored
#                              # to training\feedback.jsonl — all joined by a
#                              # per-request id. Exempt from the 7-day debug
#                              # cleanup. ~100-200 KB disk per request.

# =============================================================================
# LOCATOR
# =============================================================================
# Models whose AI bounding box is NOT trusted to corroborate a borderline OCR
# match (the pointer's "rescue" vote). Comma-separated, case-insensitive
# substrings of model names. Trust is default-ON for every model, so frontier
# models — current and future — work without editing this. Default mutes the
# managed free-tier chain (weak / degenerate grounders). Add a model here to
# mute it; set empty to trust everything. No rebuild needed.
# BBOX_DISTRUST_MODELS=nemotron,gemma,kimi
