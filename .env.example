# AI Navigator Configuration

# API Provider
API_PROVIDER=anthropic  # or "openai"
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Logging
LOG_LEVEL=INFO
DEBUG_MODE=false

# Feature Flags (for v0.2+)
ENABLE_TTS=false
ENABLE_VOICE_INPUT=false
ENABLE_A11Y_API=false

# Performance
CAPTURE_INTERVAL_MS=2000
OCR_CONFIDENCE_THRESHOLD=0.5
API_TIMEOUT_SEC=30

# Safety & Privacy
DAILY_TOKEN_CAP=100000
MONTHLY_TOKEN_CAP=5000000
COST_SAFETY_MARGIN=2.5
CAPTURE_INDICATOR_VISIBLE=true
