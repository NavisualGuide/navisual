# Navisual — Configuration
# Copy this file to .env and fill in your values.
# Only the settings you want to change need to be uncommented.

# =============================================================================
# PROVIDER SELECTION
# =============================================================================
# Which AI backend to use. Options: managed | anthropic | gemini | ollama | openai
# - managed   : Default for distributed builds. Supabase relay + OpenRouter free
#               model. No API key needed; 50 free requests per anonymous session.
#               Requires SUPABASE_URL + SUPABASE_ANON_KEY to be set.
# - anthropic : Best quality. Requires ANTHROPIC_API_KEY.
# - gemini    : Free tier (~1,500 req/day). Requires GEMINI_API_KEY.
#               Get a free key at https://aistudio.google.com/apikey
# - ollama    : Local inference. No API key. Requires Ollama running locally.
#               Install: https://ollama.com  |  Start: ollama serve
# - openai    : Requires OPENAI_API_KEY. (stub for now)

API_PROVIDER=anthropic

# =============================================================================
# SUPABASE MANAGED RELAY (S.1 — free trial, no API key required)
# =============================================================================
# Used when API_PROVIDER=managed. The anon key is a public, non-secret key
# designed to be embedded in client apps — safe to commit to source control.
# SUPABASE_URL=https://gwekzberpfuxsoddwwqj.supabase.co
# SUPABASE_ANON_KEY=<your-project-anon-key>
# MANAGED_MODEL=nvidia/nemotron-nano-12b-v2-vl:free   # OpenRouter model ID

# =============================================================================
# ANTHROPIC (Claude)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-xxx

# Model options (uncomment one, or leave default):
#   claude-haiku-4-5-20251001   — Fastest, ~20x cheaper than Sonnet. Good for testing.
#   claude-sonnet-4-6           — Default. Balanced speed + quality.
#   claude-opus-4-6             — Highest quality. Slower, ~5x cost of Sonnet.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# =============================================================================
# GOOGLE GEMINI (free tier — great for new users and testing)
# =============================================================================
# Get a free API key at https://aistudio.google.com/apikey (no credit card)
# GEMINI_API_KEY=AIza-xxx

# Primary model — used for initial task analysis and user-triggered guidance:
#   gemini-2.5-flash          — Default. Free tier, strong vision, fast. Best all-rounder.
#   gemini-2.5-pro            — Highest quality, free tier. Use if accuracy matters most.
#   gemini-3.1-flash-lite-preview — Newest free model. Worth benchmarking vs 2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# Fast model — used for automated screen-change re-queries (cheaper, less reasoning needed):
#   gemini-2.5-flash-lite     — Default. $0.10/MTok input (30x cheaper than Sonnet).
#                               Free tier available. Ideal for "did the step complete?" checks.
#   gemini-2.5-flash          — If you want consistent model across all calls.
# GEMINI_FAST_MODEL=gemini-2.5-flash-lite

# =============================================================================
# OLLAMA (local — no API key, runs on your machine)
# =============================================================================
# Requires Ollama installed and running: ollama serve
# Vision-capable models (can analyze screenshots):
#   llama3.2-vision      — Default. Best quality. Needs ~8GB VRAM or 16GB RAM.
#                          Pull: ollama pull llama3.2-vision
#   llava:7b             — Lighter alternative. ~4GB VRAM.
#                          Pull: ollama pull llava:7b
#   moondream            — Very lightweight. Minimal quality.
#                          Pull: ollama pull moondream
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2-vision
# OLLAMA_TIMEOUT_SEC=120

# =============================================================================
# OPENAI (v0.2 — stub for now)
# =============================================================================
# OPENAI_API_KEY=sk-xxx

# =============================================================================
# TOKEN BUDGET (cloud providers only — Ollama is free/local)
# =============================================================================
# Raise DAILY_TOKEN_CAP during development to avoid hitting the budget guard.
# Default 100,000 is tight when testing with the 2.5x safety margin.
# DAILY_TOKEN_CAP=1000000
# MONTHLY_TOKEN_CAP=5000000

# Safety margin multiplier applied to estimated token cost before each request.
# Default 2.5x is conservative for early versions. Lower toward 1.0 as mature.
# COST_SAFETY_MARGIN=2.5

# =============================================================================
# OVERLAY APPEARANCE
# =============================================================================
# OVERLAY_COLOR=#FF6B35        # Orange — the navigator accent color
# OVERLAY_THICKNESS=4          # Inner stroke width. White outline = 2x+2 = 10px.
# SUBTITLE_FONT_SIZE=18
# SUBTITLE_BG_OPACITY=180      # 0-255

# =============================================================================
# SCREEN CAPTURE & DETECTION
# =============================================================================
# CAPTURE_INTERVAL_MS=2000     # Idle fallback interval (event-driven is primary)
# DIFF_FPS=10                  # Pixel-diff check frequency
# DIFF_THRESHOLD=0.05          # Pixel change threshold (0-1, default 5%)
# PHASH_THRESHOLD=5            # Hamming distance for screenshot dedup
# IDLE_TIMEOUT_SEC=10          # Seconds before idle fallback check

# =============================================================================
# ELEMENT LOCATOR
# =============================================================================
# ENABLE_A11Y=true             # Use Windows UI Automation as primary locator (< 5ms)
# ENABLE_OCR=true              # Use PaddleOCR as fallback
# A11Y_TIMEOUT_MS=100          # Max time for A11y query
# OCR_CONFIDENCE_THRESHOLD=0.5

# =============================================================================
# HOTKEYS  (Alt + single key — easy one-handed use; all require restart)
# Format: alt+e | ctrl+shift+x | alt+`   Modifiers: alt ctrl shift
# =============================================================================
# NEXT_STEP_HOTKEY=alt+`       # Advance to next step (most used — easy pinky)
# CORRECTION_HOTKEY=alt+e      # Re-analyze current screen  (E = rEtry/Error)
# PAUSE_HOTKEY=alt+s           # Pause/resume capture       (S = Stop/Start)
# FLOATING_WINDOW_HOTKEY=alt+q # Show/hide Navisual panel (Q = Quit/show)
# TALK_HOTKEY=alt+a            # Push-to-talk voice input   (A = Ask/Audio)
# REREAD_HOTKEY=alt+r          # Re-read last instruction   (R = Read/Replay)

# =============================================================================
# LOGGING
# =============================================================================
# LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR
# DEBUG_MODE=false

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# ENABLE_TTS=false             # Text-to-speech (v0.2)
# ENABLE_VOICE_INPUT=false     # Voice input (v0.2)
# CAPTURE_INDICATOR_VISIBLE=true
