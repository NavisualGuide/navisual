{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Navisual",
  "version": "0.6.2",
  "identifier": "com.navisual.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "panel",
        "title": "Navisual",
        "width": 420,
        "height": 600,
        "minWidth": 360,
        "minHeight": 380,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "visible": false
      },
      {
        "label": "overlay",
        "url": "/overlay.html",
        "width": 1920,
        "height": 1080,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false,
        "shadow": false,
        "x": 0,
        "y": 0
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3QUIzQTUxNUExRkE0QQpSV1JLK3FFVnBiTjZDVTczVHltVTdjdW5VUFNUM1pPK0p4TVpaOWRpNVB5Unpzdm15OUl6cGpZbQo=",
      "endpoints": [
        "https://github.com/NavisualGuide/navisual/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["packs/**/*"],
    "publisher": "Jin Fu",
    "copyright": "Copyright 2024-2026 Jin Fu",
    "category": "Utility",
    "homepage": "https://navisualguide.com",
    "longDescription": "Navisual watches your screen and gives real-time step-by-step instructions via on-screen overlays and audio. The AI never clicks, types, or takes control — every action is yours.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
