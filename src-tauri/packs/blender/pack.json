{
  "id": "blender",
  "name": "Blender Nav-Pack",
  "version": "2.0.0",
  "min_app_version": "0.6.0",
  "target_app": "Blender",
  "window_title_pattern": "(?i)blender",
  "authoring_scale": 2.0,
  "starter_tasks": [
    "Show me around Blender",
    "Help me move an object",
    "Help me add a cube to the scene"
  ],
  "system_prompt_injection": "The user is in Blender. The left Toolbar holds the active tools (Object/Edit/Sculpt sets differ by workspace tab); the right Properties editor has a vertical tab column (Render/Output/View Layer/Scene/World/Collection/Object/Modifiers/Particles/Physics...); the 3D-viewport header along the top has the shading modes (Wireframe/Solid/Material Preview/Rendered) and Overlays/X-Ray/Gizmos toggles. Prefer the keyboard shortcut when one exists.",
  "shortcuts": {
    "Cursor": "Shift+Spacebar, Spacebar",
    "Rotate": "Shift+Spacebar, R",
    "Scale": "Shift+Spacebar, S",
    "Transform": "Shift+Spacebar, T",
    "Annotate": "Shift+Spacebar, D",
    "Measure": "Shift+Spacebar, M",
    "Add Cube": "Shift+Spacebar, 9",
    "Move": "Shift+Spacebar, G",
    "Extrude Region": "Shift+Spacebar, E",
    "Inset Faces": "Shift+Spacebar, I",
    "Bevel": "Shift+Spacebar, Ctrl B",
    "Loop Cut": "Shift+Spacebar, Ctrl R",
    "Knife": "Shift+Spacebar, K",
    "Poly Build": "Shift+Spacebar, Shift 9",
    "Spin": "Shift+Spacebar, Shift 0",
    "Smooth": "Shift+Spacebar, Ctrl 2",
    "Edge Slide": "Shift+Spacebar, Ctrl 4",
    "Shrink/Fatten": "Shift+Spacebar, Alt S",
    "Shear": "Shift+Spacebar, Shift Ctrl Alt S",
    "Rip Region": "Shift+Spacebar, V",
    "Scrape": "Shift+Spacebar, 6",
    "Multiplane Scrape": "Shift+Spacebar, 7",
    "Pinch": "Shift+Spacebar, P",
    "Grab": "Shift+Spacebar, G",
    "Elastic Deform": "Shift+Spacebar, 8",
    "Snake Hook": "Shift+Spacebar, K",
    "Thumb": "Shift+Spacebar, 9",
    "Pose": "Shift+Spacebar, 0",
    "Nudge": "Shift+Spacebar, Shift 1",
    "Slide Relax": "Shift+Spacebar, Shift 3",
    "Boundary": "Shift+Spacebar, Shift 4",
    "Cloth": "Shift+Spacebar, Shift 5",
    "Simplify": "Shift+Spacebar, Shift 6",
    "Mask": "Shift+Spacebar, Shift 7",
    "Draw Face Sets": "Shift+Spacebar, Shift 8",
    "Multires Displacement Eraser": "Shift+Spacebar, Shift 9",
    "Multires Displacement Smear": "Shift+Spacebar, Shift 0",
    "Paint": "Shift+Spacebar, Ctrl 1",
    "Smear": "Shift+Spacebar, Ctrl 2",
    "Box Mask": "Shift+Spacebar, B",
    "Box Hide": "Shift+Spacebar, Ctrl 5",
    "Box Face Set": "Shift+Spacebar, Ctrl 6",
    "Box Trim": "Shift+Spacebar, Ctrl 8",
    "Line Project": "Shift+Spacebar, Ctrl 0",
    "Mesh Filter": "Shift+Spacebar, Alt 1",
    "Cloth Filter": "Shift+Spacebar, Alt 2",
    "Color Filter": "Shift+Spacebar, Alt 3",
    "Mask by Color": "Shift+Spacebar, Alt 4"
  },
